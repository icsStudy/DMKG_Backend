{
  "name": "@spacode/api-gateway",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "dev": "node --env-file=../../.env ./node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@spacode/types": "workspace:*",
    "@spacode/utils": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "http-proxy-middleware": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
