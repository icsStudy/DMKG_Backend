# Database
DATABASE_URL=postgresql://spacode:spacode@localhost:5433/spacode

# Redis
REDIS_URL=redis://localhost:6379

# JWT (RS256) — generate with:
# openssl genrsa -out jwt-private.pem 2048
# openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Encryption (AES-256-GCM, 32 bytes base64)
# openssl rand -base64 32
ENCRYPTION_KEY=

# Service URLs (internal — localhost in unified prod container / docker-compose dev)
CORE_SERVICE_URL=http://localhost:3010
AI_SERVICE_URL=http://localhost:3020
SOCIAL_SERVICE_URL=http://localhost:3030

# API Gateway
PORT=3000
BUILD_REF=local
PUBLIC_API_KEY=sk_pub_dev
ADMIN_API_KEY=sk_admin_dev
ADMIN_ALLOWED_EMAIL=admin@spacode.co.il
CORS_ORIGIN=http://localhost:3060

# Core Service
CORE_PORT=3010

# AI Service
AI_PORT=3020

# Social Service
SOCIAL_PORT=3030

# Stripe (optional for billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth (optional — idToken flow uses GOOGLE_CLIENT_ID only)
# See docs/setup/google-oauth.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI providers (optional)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
MANUS_API_KEY=
FAL_API_KEY=

# Email (optional)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Social / Meta / WhatsApp
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/v1/social/callback/meta
META_GRAPH_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=spacode-meta-verify
WHATSAPP_WEBHOOK_VERIFY_TOKEN=spacode-wa-verify
META_WABA_CONFIG_ID=
PUBLIC_API_URL=http://localhost:3000

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/v1/social/callback/tiktok
TIKTOK_WEBHOOK_VERIFY_TOKEN=spacode-tiktok-verify
TIKTOK_PUBLISH_PRIVACY=SELF_ONLY

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/v1/social/callback/linkedin

# X (Twitter)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/v1/social/callback/twitter

# YouTube (or reuse GOOGLE_CLIENT_ID/SECRET)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/v1/social/callback/youtube

# Worker Service
SOCIAL_PUBLISH_MAX_MS=600000
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=
MANUS_API_KEY=

